# Production environment template (Vercel → Project → Settings → Environment Variables)
# Root Directory for deploy: backend

NODE_ENV=production
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/food-order-app?retryWrites=true&w=majority
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
CLIENT_URL=https://your-app.vercel.app
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
